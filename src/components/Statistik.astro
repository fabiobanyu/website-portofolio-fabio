      <!-- YouTube -->
      <a href="https://www.youtube.com/@fbc_maestro" target="_blank" class="stat-card" id="stat-yt">
        <div class="stat-icon-wrap stat-icon-red">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-label">YouTube</span>
          <span class="stat-value">@fbc_maestro</span>
        </div>
        <div class="stat-arrow">→</div>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/fabio-banyu-cyto" target="_blank" class="stat-card" id="stat-li">
        <div class="stat-icon-wrap stat-icon-blue">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-label">LinkedIn</span>
          <span class="stat-value">Fabio Banyu Cyto</span>
        </div>
        <div class="stat-arrow">→</div>
      </a>
    </div>
  </div>
</section>

<style>
  .statistik {
    position: relative;
    padding: 40px 0;
    background: var(--bg-secondary);
    border-top: 1px solid rgba(0, 240, 255, 0.05);
    border-bottom: 1px solid rgba(0, 240, 255, 0.05);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .stat-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--bg-glass);
    backdrop-filter: blur(15px);
    border: 1px solid rgba(0, 240, 255, 0.08);
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0, 240, 255, 0.03), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .stat-card:hover {
    border-color: rgba(0, 240, 255, 0.25);
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(0, 240, 255, 0.08);
  }

  .stat-card:hover::before {
    opacity: 1;
  }

  .stat-icon-wrap {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 240, 255, 0.08);
    border-radius: 10px;
    color: var(--cyan);
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .stat-icon-red {
    background: rgba(255, 0, 0, 0.08);
    color: #ff4444;
  }

  .stat-icon-blue {
    background: rgba(10, 102, 194, 0.08);
    color: #0a66c2;
  }

  .stat-card:hover .stat-icon-wrap {
    transform: scale(1.1);
    box-shadow: 0 0 20px rgba(0, 240, 255, 0.2);
  }

  .stat-card:hover .stat-icon-red {
    box-shadow: 0 0 20px rgba(255, 0, 0, 0.2);
  }

  .stat-card:hover .stat-icon-blue {
    box-shadow: 0 0 20px rgba(10, 102, 194, 0.2);
  }

  .stat-icon {
    width: 22px;
    height: 22px;
  }

  .stat-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--text-primary);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .stat-arrow {
    font-size: 1.1rem;
    color: var(--text-dim);
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateX(-8px);
  }

  .stat-card:hover .stat-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--cyan);
  }

  @media (max-width: 900px) {
    .stat-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
