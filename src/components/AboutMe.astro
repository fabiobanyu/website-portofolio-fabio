---
/* About Me Section - Bio, Skills, Education */
---

<section class="about section" id="about">
  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      <span class="section-label">Get to know me</span>
      <h2 class="section-title">About <span class="text-cyan">Me</span></h2>
    </div>

    <div class="about-grid">
      <!-- Left - Bio -->
      <div class="about-bio">
        <div class="bio-card glass-card">
          <div class="corner-decoration top-left"></div>
          <div class="corner-decoration top-right"></div>
          <div class="corner-decoration bottom-left"></div>
          <div class="corner-decoration bottom-right"></div>

          <p class="bio-text">
            Halo! Saya <span class="text-cyan">Fabio Banyu Cyto</span>, mahasiswa S1 Sains Data di 
            <span class="text-gold">Institut Teknologi Sumatera (ITERA)</span>. Saya memiliki 
            ketertarikan pada bidang pemodelan data, komputasi visual, serta pengembangan sistem berbasis AI.
            Selain itu, saya juga seorang beginner Front-End Developer yang membangun web fungsional. 
            Saya memiliki motivasi tinggi untuk terus belajar di bidang data science, machine learning, dan web development.
          </p>

          <!-- Info Grid -->
          <div class="info-grid">
            <div class="info-item">
              <span class="info-icon">📍</span>
              <div class="info-detail">
                <span class="info-key">Location</span>
                <span class="info-val">Bandar Lampung, Lampung</span>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">🎓</span>
              <div class="info-detail">
                <span class="info-key">University</span>
                <span class="info-val">Institut Teknologi Sumatera</span>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">🎂</span>
              <div class="info-detail">
                <span class="info-key">Birthday</span>
                <span class="info-val">14 Februari 2005</span>
              </div>
            </div>
            <div class="info-item">
              <span class="info-icon">✉️</span>
              <div class="info-detail">
                <span class="info-key">Email</span>
                <span class="info-val">fabiocyto74@gmail.com</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Center - Education -->
      <div class="about-edu">
        <div class="edu-card glass-card">
          <div class="corner-decoration top-left"></div>
          <div class="corner-decoration top-right"></div>
          <div class="corner-decoration bottom-left"></div>
          <div class="corner-decoration bottom-right"></div>

          <h3 class="edu-title">
            <span class="text-cyan">//</span> Education
          </h3>
          <div class="timeline">
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <span class="timeline-year">Aug 2023 - Expected 2027</span>
                <h4 class="timeline-name">Institut Teknologi Sumatera</h4>
                <p class="timeline-desc">S1 Sains Data (GPA: 3.57/4.00)</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <span class="timeline-year">Jul 2020 - May 2023</span>
                <h4 class="timeline-name">SMA Darul Fattah</h4>
                <p class="timeline-desc">Takhosus Bahasa Inggris</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <span class="timeline-year">2017 - 2020</span>
                <h4 class="timeline-name">SMP Global Madani</h4>
                <p class="timeline-desc">Junior High School</p>
              </div>
            </div>
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <span class="timeline-year">2011 - 2017</span>
                <h4 class="timeline-name">SD Global Madani</h4>
                <p class="timeline-desc">Elementary School</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right - Skills -->
      <div class="about-skills">
        <div class="skills-card glass-card">
          <div class="corner-decoration top-left"></div>
          <div class="corner-decoration top-right"></div>
          <div class="corner-decoration bottom-left"></div>
          <div class="corner-decoration bottom-right"></div>

          <h3 class="skills-title">
            <span class="text-cyan">//</span> Tech Stack
          </h3>

          <!-- Skills -->
          <div class="skill-list">
            <div class="skill-item" data-percent="95">
              <div class="skill-header">
                <span class="skill-name">Python</span>
                <span class="skill-percent">95%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="--fill: 95%"></div>
              </div>
            </div>

            <div class="skill-item" data-percent="90">
              <div class="skill-header">
                <span class="skill-name">R</span>
                <span class="skill-percent">90%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="--fill: 90%"></div>
              </div>
            </div>

            <div class="skill-item" data-percent="85">
              <div class="skill-header">
                <span class="skill-name">Jupyter</span>
                <span class="skill-percent">85%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="--fill: 85%"></div>
              </div>
            </div>

            <div class="skill-item" data-percent="80">
              <div class="skill-header">
                <span class="skill-name">HTML / CSS</span>
                <span class="skill-percent">80%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="--fill: 80%"></div>
              </div>
            </div>

            <div class="skill-item" data-percent="70">
              <div class="skill-header">
                <span class="skill-name">JavaScript</span>
                <span class="skill-percent">70%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="--fill: 70%"></div>
              </div>
            </div>

            <div class="skill-item" data-percent="65">
              <div class="skill-header">
                <span class="skill-name">React / TypeScript</span>
                <span class="skill-percent">65%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="--fill: 65%"></div>
              </div>
            </div>

            <div class="skill-item" data-percent="60">
              <div class="skill-header">
                <span class="skill-name">Node.js / Backend</span>
                <span class="skill-percent">60%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-fill" style="--fill: 60%"></div>
              </div>
            </div>
          </div>

          <!-- Tech Tags -->
          <div class="tech-tags">
            <span class="tech-tag">HTML</span>
            <span class="tech-tag">CSS</span>
            <span class="tech-tag">JavaScript</span>
            <span class="tech-tag">Python</span>
            <span class="tech-tag">R</span>
            <span class="tech-tag">Machine Learning</span>
            <span class="tech-tag">Data Modeling</span>
            <span class="tech-tag">AI</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Section Header */
  .section-header {
    margin-bottom: 50px;
  }

  /* About Grid */
  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    align-items: stretch;
  }
  .about-bio, .about-edu, .about-skills {
    display: flex;
    flex-direction: column;
  }
  .about-bio .glass-card, .about-edu .glass-card, .about-skills .glass-card {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Bio Card */
  .bio-card {
    position: relative;
  }

  .bio-text {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 28px;
  }

  /* Info Grid */
  .info-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px;
    background: rgba(0, 240, 255, 0.02);
    border: 1px solid rgba(0, 240, 255, 0.05);
    border-radius: 8px;
    transition: all 0.3s ease;
  }
  .info-item:hover {
    border-color: rgba(0, 240, 255, 0.15);
    background: rgba(0, 240, 255, 0.04);
  }

  .info-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-detail {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .info-key {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .info-val {
    font-size: 0.82rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* Education */
  .edu-card {
    position: relative;
  }

  .edu-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 20px;
    letter-spacing: 0.05em;
  }

  .timeline {
    position: relative;
    padding-left: 24px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, var(--cyan), transparent);
  }
  .timeline.timeline-gold::before {
    background: linear-gradient(to bottom, var(--gold), transparent);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 20px;
  }
  .timeline-item:last-child {
    padding-bottom: 8px;
  }

  .timeline-dot {
    position: absolute;
    left: -26px; /* Shift slightly for a bigger dot */
    top: 4px;
    width: 12px;
    height: 12px;
    background: var(--cyan);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--cyan-glow);
  }
  .timeline.timeline-gold .timeline-dot {
    background: var(--gold);
    box-shadow: 0 0 10px var(--gold-glow);
  }

  .timeline-year {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--cyan);
    letter-spacing: 0.1em;
  }
  .timeline.timeline-gold .timeline-year {
    color: var(--gold);
  }

  .timeline-name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 4px 0 2px;
  }

  .timeline-desc {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.4;
  }

  /* Skills Card */
  .skills-card {
    position: relative;
  }

  .skills-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 24px;
    letter-spacing: 0.05em;
  }

  /* Skill Bars */
  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-bottom: 28px;
  }

  .skill-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-primary);
    letter-spacing: 0.03em;
  }

  .skill-percent {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cyan);
  }

  .skill-bar {
    width: 100%;
    height: 4px;
    background: rgba(0, 240, 255, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--cyan), var(--gold));
    border-radius: 4px;
    transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 0 8px rgba(0, 240, 255, 0.3);
  }

  .skill-fill.animated {
    width: var(--fill);
  }

  /* Tech Tags */
  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-top: 20px;
    border-top: 1px solid rgba(0, 240, 255, 0.08);
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-secondary);
    padding: 5px 12px;
    background: rgba(0, 240, 255, 0.04);
    border: 1px solid rgba(0, 240, 255, 0.1);
    border-radius: 4px;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    cursor: default;
  }
  .tech-tag:hover {
    color: var(--cyan);
    border-color: var(--cyan);
    background: rgba(0, 240, 255, 0.08);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0, 240, 255, 0.1);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Animate skill bars on scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const fills = entry.target.querySelectorAll('.skill-fill');
          fills.forEach((fill, i) => {
            setTimeout(() => {
              fill.classList.add('animated');
            }, i * 150);
          });
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  const skillSection = document.querySelector('.skill-list');
  if (skillSection) {
    observer.observe(skillSection);
  }

  // Scroll reveal for about section
  const aboutObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          aboutObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.about-bio, .about-edu, .about-skills').forEach((el) => {
    el.classList.add('reveal-element');
    aboutObserver.observe(el);
  });
</script>

<style is:global>
  .reveal-element {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .reveal-element.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .about-edu.reveal-element {
    transition-delay: 0.2s;
  }
  .about-skills.reveal-element {
    transition-delay: 0.4s;
  }
</style>
