---
/* Hero Section - Cyberpunk Futuristic */
---

<section class="hero" id="hero">
  <!-- Background Elements -->
  <canvas class="hero-particles" id="heroParticles"></canvas>
  <div class="hero-grid"></div>
  
  <div class="hero-container">
    <!-- Left Content -->
    <div class="hero-content">
      <!-- Status Badge -->
      <div class="hero-badge">
        <span class="badge-dot"></span>
        <span class="badge-text">Available for opportunities</span>
      </div>

      <!-- Name with Glitch Effect -->
      <h1 class="hero-name">
        <span class="name-prefix">Hi, I'm</span>
        <span class="name-block">
          <span class="name-first">Fabio Banyu</span>
          <span class="name-last" data-text="Cyto">Cyto</span>
        </span>
      </h1>

      <!-- Typing Role -->
      <div class="hero-role">
        <span class="role-bracket">&lt;</span>
        <span class="role-inner">
          <span class="role-text" id="roleText"></span>
          <span class="role-cursor">|</span>
        </span>
        <span class="role-bracket">&gt;</span>
      </div>

      <!-- Description -->
      <p class="hero-desc">
        Mahasiswa <span class="text-cyan">Institut Teknologi Sumatera</span> yang passionate
        dalam pengembangan web dan data science. Membangun solusi digital yang inovatif
        dan futuristik.
      </p>

      <!-- CTA Buttons -->
      <div class="hero-cta">
        <a href="#portfolio" class="btn-primary glow-hover">
          <span class="btn-text">View Projects</span>
          <span class="btn-arrow">→</span>
        </a>
        <a href="https://wa.me/6285769715375?text=Halo%20Fabio%2C%20saya%20tertarik%20dengan%20portfolio%20kamu!" class="btn-secondary glow-hover" target="_blank">
          <span class="btn-text">Contact Me</span>
        </a>
      </div>

      <!-- Social Links Mini -->
      <div class="hero-socials">
        <a href="https://github.com/fabiobanyu" target="_blank" class="social-link" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
        </a>
        <a href="https://linkedin.com/in/fabio-banyu-cyto" target="_blank" class="social-link" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://instagram.com/biyokcb" target="_blank" class="social-link" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="mailto:fabiocyto74@gmail.com?subject=Portfolio%20Inquiry" class="social-link" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <div class="social-line"></div>
      </div>
    </div>

    <!-- Right - Photo -->
    <div class="hero-visual">
      <div class="photo-portal-wrapper">
        <div class="photo-frame">
          <div class="photo-glow"></div>
          <div class="photo-slider" id="photoSlider">
            <div class="slider-track">
              <img src="/profile.png" alt="Fabio Banyu Cyto 1" class="slide active" />
              <img src="/profile-2.jpg" alt="Fabio Banyu Cyto 2" class="slide" />
              <img src="/profile-3.jpg" alt="Fabio Banyu Cyto 3" class="slide" />
            </div>
            <button class="slider-ctrl prev" id="slidePrev" aria-label="Previous">❮</button>
            <button class="slider-ctrl next" id="slideNext" aria-label="Next">❯</button>
          </div>
          <!-- Corner Decorations -->
          <div class="corner-decoration top-left"></div>
          <div class="corner-decoration top-right"></div>
          <div class="corner-decoration bottom-left"></div>
          <div class="corner-decoration bottom-right"></div>
        </div>
      </div>

      <!-- Floating Chips -->
      <div class="float-chip chip-1">
        <span class="chip-value">15+</span>
        <span class="chip-label">Projects</span>
      </div>
      <div class="float-chip chip-2">
        <span class="chip-value">8+</span>
        <span class="chip-label">Certificates</span>
      </div>
      <div class="float-chip chip-3">
        <span class="chip-value">ITERA</span>
        <span class="chip-label">University</span>
      </div>
      <div class="float-chip chip-4">
        <span class="chip-label">Data Science</span>
      </div>
      <div class="float-chip chip-5">
        <span class="chip-label">AI Research</span>
      </div>
      <div class="float-chip chip-6">
        <span class="chip-label">Machine Learning</span>
      </div>
      <div class="float-chip chip-7">
        <span class="chip-label">Python</span>
      </div>
      <div class="float-chip chip-8">
        <span class="chip-label">Jupyter</span>
      </div>
      <div class="float-chip chip-9">
        <span class="chip-label">SQL</span>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <div class="scroll-line">
      <div class="scroll-dot"></div>
    </div>
    <span class="scroll-text">Scroll</span>
  </div>

  <!-- Tech Ticker -->
  <div class="ticker-strip">
    <div class="ticker-track">
      <span class="ticker-item">Python</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">R</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">Jupyter</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">HTML</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">CSS</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">JavaScript</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">TypeScript</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">Node.js</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">Python</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">R</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">Jupyter</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">HTML</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">CSS</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">JavaScript</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">TypeScript</span>
      <span class="ticker-sep">◆</span>
      <span class="ticker-item">Node.js</span>
      <span class="ticker-sep">◆</span>
    </div>
  </div>
</section>

<style>
  /* --- Hero Section --- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-top: 80px;
  }

  .hero-particles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(rgba(0, 240, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 240, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 2; /* Still behind content (z-index 10) */
    mask-image: radial-gradient(circle at center, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(circle at center, black 30%, transparent 80%);
    pointer-events: none;
  }

  /* Hero Container */
  .hero-container {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  /* --- Hero Content (Left) --- */
  .hero-content {
    animation: fadeInUp 0.8s ease-out;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(0, 255, 136, 0.06);
    border: 1px solid rgba(0, 255, 136, 0.2);
    border-radius: 50px;
    margin-bottom: 24px;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    background: #00ff88;
    border-radius: 50%;
    animation: blink 2s ease-in-out infinite;
  }
  .badge-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #00ff88;
    letter-spacing: 0.05em;
  }

  /* Name */
  .hero-name {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .name-prefix {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-bottom: 8px;
    letter-spacing: 0.1em;
  }
  .name-block {
    display: block;
  }
  .name-first {
    color: var(--text-primary);
    margin-right: 12px;
  }
  .name-last {
    color: var(--cyan);
    position: relative;
    display: inline-block;
  }
  .name-last::before,
  .name-last::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .name-last::before {
    color: var(--magenta);
    animation: glitch-1 3s infinite linear alternate-reverse;
    z-index: -1;
  }
  .name-last::after {
    color: var(--gold);
    animation: glitch-2 2s infinite linear alternate-reverse;
    z-index: -1;
  }

  /* Role */
  .hero-role {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin: 0 auto 20px;
    color: var(--text-secondary);
    width: fit-content;
  }
  .role-bracket {
    color: var(--text-dim);
    flex-shrink: 0;
  }
  .role-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 0;
  }
  .role-text {
    color: var(--gold);
    text-align: center;
    white-space: nowrap;
  }
  .role-cursor {
    color: var(--cyan);
    animation: blink 0.8s step-end infinite;
    font-weight: 300;
    flex-shrink: 0;
  }

  /* Description */
  .hero-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 500px;
    margin-bottom: 28px;
  }

  /* CTA Buttons */
  .hero-cta {
    display: flex;
    gap: 16px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 28px;
    background: linear-gradient(135deg, var(--cyan), #0088aa);
    color: var(--bg-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
  }
  .btn-primary:hover::before {
    left: 100%;
  }
  .btn-primary:hover {
    box-shadow: 0 0 30px rgba(0, 240, 255, 0.4);
    transform: translateY(-2px);
    color: var(--bg-primary);
  }
  .btn-arrow {
    transition: transform 0.3s ease;
  }
  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 28px;
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-secondary:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(223, 201, 101, 0.05);
  }

  /* Socials */
  .hero-socials {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .social-link {
    color: var(--text-dim);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid transparent;
  }
  .social-link:hover {
    color: var(--cyan);
    border-color: rgba(0, 240, 255, 0.2);
    background: rgba(0, 240, 255, 0.05);
    transform: translateY(-3px);
  }
  .social-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, var(--text-dim), transparent);
    margin-left: 4px;
  }

  /* --- Hero Visual (Right) --- */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    animation: fadeInUp 1s ease-out 0.2s both;
  }

  .photo-portal-wrapper {
    position: relative;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 20;
  }

  /* Photo Frame */
  .photo-frame {
    position: relative;
    width: 320px;
    height: 380px;
    border-radius: 12px;
    z-index: 2;
    overflow: hidden; /* Keep the photo inside */
    border: 1px solid rgba(0, 255, 255, 0.35);
    box-shadow: 
      0 0 30px rgba(0, 255, 255, 0.25),
      0 0 60px rgba(0, 255, 255, 0.15),
      0 0 100px rgba(0, 255, 255, 0.08),
      inset 0 0 30px rgba(0, 255, 255, 0.05);
  }

  /* Refined Soft Oval Portal - Moved to wrapper for unclipped glow */
  .photo-portal-wrapper::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 150%;
    height: 130%;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 255, 255, 0.45) 0%,
      rgba(0, 255, 255, 0.12) 45%,
      transparent 75%
    );
    border-radius: 50%;
    z-index: 1;
    filter: blur(25px);
    animation: portal-aura 6s ease-in-out infinite;
    opacity: 0.9;
  }

  .photo-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle at center,
      rgba(0, 240, 255, 0.1) 0%,
      transparent 50%
    );
    animation: float 6s ease-in-out infinite;
    pointer-events: none;
  }
  
  .photo-slider {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 2;
  }
  .slider-track {
    width: 100%;
    height: 100%;
    position: relative;
  }
  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.8s ease-in-out, transform 0.8s ease-in-out;
    transform: scale(1.1);
  }
  .slide.active {
    opacity: 1;
    transform: scale(1);
    z-index: 3;
  }
  
  .slider-ctrl {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(10, 10, 20, 0.6);
    border: 1px solid rgba(0, 240, 255, 0.3);
    color: var(--cyan);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
    opacity: 0;
  }
  .photo-slider:hover .slider-ctrl {
    opacity: 1;
  }
  .slider-ctrl:hover {
    background: var(--cyan);
    color: var(--bg-primary);
    box-shadow: 0 0 15px var(--cyan);
  }
  .slider-ctrl.prev { left: 10px; }
  .slider-ctrl.next { right: 10px; }

  .photo-frame .corner-decoration::before,
  .photo-frame .corner-decoration::after {
    background: var(--cyan);
  }

  /* Floating Chips */
  .float-chip {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 16px;
    background: rgba(10, 10, 20, 0.85);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 240, 255, 0.15);
    border-radius: 8px;
    animation: float 4s ease-in-out infinite;
    z-index: 5;
  }
  .chip-value {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--cyan);
  }
  .chip-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  .chip-1 {
    top: 10%;
    right: -20px;
    animation-delay: 0s;
  }
  .chip-2 {
    bottom: 20%;
    right: -30px;
    animation-delay: 1s;
  }
  .chip-3 {
    bottom: 5%;
    left: -20px;
    animation-delay: 2s;
  }
  .chip-4 {
    top: -5%;
    right: -35%;
    animation-delay: 2s;
  }
  .chip-5 {
    bottom: -15%;
    right: 20%;
    animation-delay: 0.5s;
  }
  .chip-6 {
    top: 55%;
    right: -15%;
    animation-delay: 2.5s;
  }
  .chip-7 {
    bottom: -25%;
    right: 25%;
    animation-delay: 1.2s;
  }
  .chip-8 {
    top: 75%;
    right: -35%;
    animation-delay: 0.8s;
  }
  .chip-9 {
    bottom: -25%;
    left: -5%;
    animation-delay: 1.8s;
  }

  /* --- Scroll Indicator --- */
  .scroll-indicator {
    position: absolute;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 10;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(0, 240, 255, 0.15);
    position: relative;
    overflow: hidden;
    border-radius: 1px;
  }
  .scroll-dot {
    width: 3px;
    height: 8px;
    background: var(--cyan);
    border-radius: 2px;
    position: absolute;
    left: -1px;
    animation: scroll-indicator 2s ease-in-out infinite;
  }
  .scroll-text {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* --- Ticker Strip --- */
  .ticker-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 12px 0;
    background: rgba(0, 240, 255, 0.02);
    border-top: 1px solid rgba(0, 240, 255, 0.06);
    overflow: hidden;
    z-index: 10;
  }
  .ticker-track {
    display: flex;
    gap: 24px;
    white-space: nowrap;
    animation: ticker-scroll 30s linear infinite;
  }
  .ticker-item {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .ticker-sep {
    color: rgba(0, 240, 255, 0.2);
    font-size: 0.5rem;
    flex-shrink: 0;
  }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }
    .hero-content {
      order: 2;
    }
    .hero-visual {
      order: 1;
    }
    .hero-desc {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-badge {
      justify-content: center;
    }
    .hero-cta {
      justify-content: center;
    }
    .hero-socials {
      justify-content: center;
    }
    .social-line {
      display: none;
    }
    .photo-frame {
      width: 240px;
      height: 290px;
    }
    .role-text {
      min-width: auto;
    }
    .hero-role {
      justify-content: center;
    }
    .float-chip {
      display: none;
    }
    .scroll-indicator {
      bottom: 60px;
    }
  }

  @media (max-width: 480px) {
    .hero-name {
      font-size: 1.8rem;
    }
    .hero-role {
      font-size: 0.75rem;
    }
    .photo-frame {
      width: 200px;
      height: 240px;
    }
  }

  @keyframes portal-aura {
    0%, 100% { transform: translate(-50%, -50%) scale(1); filter: blur(25px); opacity: 0.7; }
    50% { transform: translate(-50%, -50%) scale(1.05); filter: blur(35px); opacity: 0.4; }
  }
</style>

<script>
  // --- Typing Effect ---
  const roles = [
    'Full Stack Web Developer',
    'Data Scientist',
    'UI/UX Enthusiast',
    'Machine Learning'
  ];
  
  const roleText = document.getElementById('roleText');
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function typeRole() {
    if (!roleText) return;
    const current = roles[roleIndex];

    if (!isDeleting) {
      roleText.textContent = current.substring(0, charIndex + 1);
      charIndex++;

      if (charIndex === current.length) {
        isDeleting = true;
        setTimeout(typeRole, 2000);
        return;
      }
    } else {
      roleText.textContent = current.substring(0, charIndex - 1);
      charIndex--;

      if (charIndex === 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
      }
    }

    setTimeout(typeRole, isDeleting ? 40 : 80);
  }
  typeRole();

  // --- Hero Particles ---
  const canvas = document.getElementById('heroParticles') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let particles: any[] = [];
    let w: number, h: number;

    function resize() {
      const container = canvas.parentElement;
      if (container) {
        w = canvas.width = container.offsetWidth;
        h = canvas.height = container.offsetHeight;
      }
    }

    window.addEventListener('resize', resize);
    resize();

    class Particle {
      x: number; y: number; size: number; spX: number; spY: number; opacity: number;
      constructor() {
        this.x = Math.random() * w;
        this.y = Math.random() * h;
        this.size = Math.random() * 1.5 + 0.5;
        this.spX = (Math.random() - 0.5) * 0.4;
        this.spY = (Math.random() - 0.5) * 0.4;
        this.opacity = Math.random() * 0.5 + 0.2;
      }
      update() {
        this.x += this.spX;
        this.y += this.spY;
        if (this.x < 0) this.x = w;
        if (this.x > w) this.x = 0;
        if (this.y < 0) this.y = h;
        if (this.y > h) this.y = 0;
      }
      draw() {
        if (!ctx) return;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(0, 240, 255, ${this.opacity})`;
        ctx.fill();
      }
    }

    function init() {
      particles = [];
      for (let i = 0; i < 50; i++) particles.push(new Particle());
    }

    function animate() {
      if (!ctx) return;
      ctx.clearRect(0, 0, w, h);
      particles.forEach(p => {
        p.update();
        p.draw();
      });
      requestAnimationFrame(animate);
    }

    init();
    animate();
  }

  // --- Photo Slider ---
  const slides = document.querySelectorAll('.slide');
  const prevBtn = document.getElementById('slidePrev');
  const nextBtn = document.getElementById('slideNext');
  let currentSlide = 0;
  let slideInterval: any;

  function showSlide(index: number) {
    if (!slides.length) return;
    slides.forEach(s => s.classList.remove('active'));
    currentSlide = (index + slides.length) % slides.length;
    slides[currentSlide].classList.add('active');
  }

  function nextSlide() {
    showSlide(currentSlide + 1);
  }

  function prevSlide() {
    showSlide(currentSlide - 1);
  }

  function startAutoSlide() {
    stopAutoSlide();
    slideInterval = setInterval(nextSlide, 5000);
  }

  function stopAutoSlide() {
    if (slideInterval) clearInterval(slideInterval);
  }

  if (prevBtn && nextBtn) {
    prevBtn.addEventListener('click', () => {
      prevSlide();
      startAutoSlide();
    });
    nextBtn.addEventListener('click', () => {
      nextSlide();
      startAutoSlide();
    });
  }

  // Start initial timer
  startAutoSlide();

  // Parallax Effect for floating chips
  const heroSection = document.getElementById('hero');
  const floatChips = document.querySelectorAll('.float-chip');
  
  if (heroSection) {
    heroSection.addEventListener('mousemove', (e: any) => {
      const mouseX = (e.clientX / window.innerWidth) - 0.5;
      const mouseY = (e.clientY / window.innerHeight) - 0.5;
      
      floatChips.forEach((chip: any, i) => {
        const depth = (i + 1) * 30;
        const moveX = mouseX * depth;
        const moveY = mouseY * depth;
        chip.style.transform = `translate(${moveX}px, ${moveY}px)`;
      });
    });
  }
</script>
